pipeline {
    agent any

    environment {
        ECR_REPO   = "379220350808.dkr.ecr.ap-south-1.amazonaws.com/catalogue-service"
        ECR_REGION = "ap-south-1"
        IMAGE_TAG  = "${env.GIT_COMMIT.take(7)}"
        EC2_HOST   = "35.78.108.187"
        EC2_USER   = "ubuntu"
    }

    stages {
        stage('Checkout Application') {
            steps {
                dir('app') {
                    git branch: 'main', url: 'https://github.com/Yeswanth07/agri-catalogue-service.git'
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir('app') {
                    sh '''
                        mkdir -p .mvn/wrapper
                        cat <<EOF > .mvn/wrapper/maven-wrapper.properties
distributionUrl=https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.5/apache-maven-3.9.5-bin.zip
wrapperUrl=https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar
EOF
                        chmod +x mvnw
                        ./mvnw clean package -DskipTests -B
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('app') {
                    sh "docker build -t ${ECR_REPO}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Push to ECR') {
            steps {
                dir('app') {
                    sh """
                        aws ecr get-login-password --region ${ECR_REGION} | \
                            docker login --username AWS --password-stdin ${ECR_REPO}
                        docker push ${ECR_REPO}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Inject Secrets & Deploy') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'DB_CREDENTIALS', usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS'),
                    usernamePassword(credentialsId: 'ES_CREDENTIALS', usernameVariable: 'ES_USER', passwordVariable: 'ES_PASS')
                ]) {
                    withCredentials([sshUserPrivateKey(credentialsId: 'ec2-deploy-key', keyFileVariable: 'SSH_KEY')]) {
                        sh """
                            # Inject secrets securely without exposing them in shell history
                            ssh -i \$SSH_KEY -o StrictHostKeyChecking=no ubuntu@\${EC2_HOST} '
                                kubectl create secret generic catalogue-service-secrets -n app \\
                                    --from-literal=SPRING_DATASOURCE_USERNAME="\${DB_USER}" \\
                                    --from-literal=SPRING_DATASOURCE_PASSWORD="\${DB_PASS}" \\
                                    --from-literal=ELASTICSEARCH_USERNAME="\${ES_USER}" \\
                                    --from-literal=ELASTICSEARCH_PASSWORD="\${ES_PASS}" \\
                                    --dry-run=client -o yaml | kubectl apply -f -
                            '
                            
                            # Copy the helm charts to the EC2 instance
                            scp -i \$SSH_KEY -o StrictHostKeyChecking=no -r ./helm ubuntu@\${EC2_HOST}:~/helm

                            # Deploy the application
                            ssh -i \$SSH_KEY -o StrictHostKeyChecking=no ubuntu@\${EC2_HOST} '
                                if /usr/local/bin/helm status catalogue-service -n app >/dev/null 2>&1; then
                                    /usr/local/bin/helm upgrade catalogue-service ~/helm/catalogue-service \\
                                        -n app --reuse-values --set image.tag=\${IMAGE_TAG}
                                else
                                    /usr/local/bin/helm upgrade --install catalogue-service ~/helm/catalogue-service \\
                                        -n app --set image.tag=\${IMAGE_TAG}
                                fi
                            '
                        """
                    }
                }
            }
        }

        stage('Smoke Test') {
            steps {
                withCredentials([string(credentialsId: 'SMOKETEST_API_KEY', variable: 'API_KEY')]) {
                    sh """
                        curl -sf http://${EC2_HOST}:30080/cropcategory/v1/read/smoketest \
                            -H "apikey: \${API_KEY}" || exit 1
                    """
                }
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed — check stage logs above for details."
        }
        success {
            echo "Deployment of ${IMAGE_TAG} completed successfully."
        }
    }
}
