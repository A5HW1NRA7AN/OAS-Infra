pipeline {
    agent any

    // The target node IP is environment-specific and changes per provisioning —
    // it is passed in at build time (terraform output node_public_ip), never
    // hardcoded in SCM.
    parameters {
        string(
            name: 'EC2_HOST',
            defaultValue: '',
            description: 'Public IP / DNS of the K8s node (terraform output: node_public_ip).'
        )
    }

    environment {
        IMAGE_TAG = "${env.GIT_COMMIT.take(7)}"
        EC2_USER  = "ubuntu"
    }

    stages {
        stage('Load Config') {
            steps {
                script {
                    if (!params.EC2_HOST?.trim()) {
                        error("EC2_HOST parameter is required (terraform output node_public_ip).")
                    }
                    // Dependency-free reads from the single source of truth.
                    def cfg = { key ->
                        sh(
                            script: "grep -E '^[[:space:]]*${key}:' service.config.yaml | head -1 | awk '{print \$2}'",
                            returnStdout: true
                        ).trim()
                    }
                    env.ECR_REPO_NAME = cfg('ecr_repository_name')
                    env.ECR_REGION    = cfg('ecr_region')
                    env.HELM_RELEASE  = cfg('release_name')
                    env.HELM_CHART    = cfg('chart_path')      // e.g. helm/catalogue-service
                    env.APP_NAMESPACE = cfg('namespace')
                    env.SMOKE_PREFIX  = cfg('smoke_test_prefix')
                    env.SMOKE_API_KEY = cfg('api_key')
                    env.APP_REPO_URL    = cfg('url')
                    env.APP_REPO_BRANCH = cfg('branch')

                    // Derive the AWS account ID — never hardcode it.
                    env.AWS_ACCOUNT_ID = sh(
                        script: "aws sts get-caller-identity --query Account --output text",
                        returnStdout: true
                    ).trim()
                    env.ECR_REPO = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.ECR_REGION}.amazonaws.com/${env.ECR_REPO_NAME}"

                    echo "Deploy target : ${params.EC2_HOST}"
                    echo "ECR repository: ${env.ECR_REPO}"
                    echo "Helm release  : ${env.HELM_RELEASE} (ns: ${env.APP_NAMESPACE})"
                }
            }
        }

        stage('Checkout Application') {
            steps {
                dir('app') {
                    git branch: env.APP_REPO_BRANCH, url: env.APP_REPO_URL
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir('app') {
                    sh '''
                        mkdir -p .mvn/wrapper
                        cat <<EOF > .mvn/wrapper/maven-wrapper.properties
distributionUrl=https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.5/apache-maven-3.9.5-bin.zip
wrapperUrl=https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar
EOF
                        chmod +x mvnw
                        ./mvnw clean package -DskipTests -B
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('app') {
                    sh "docker build -t ${ECR_REPO}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Push to ECR') {
            steps {
                dir('app') {
                    sh """
                        aws ecr get-login-password --region ${ECR_REGION} | \
                            docker login --username AWS --password-stdin ${ECR_REPO}
                        docker push ${ECR_REPO}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Inject Secrets & Deploy') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'DB_CREDENTIALS', usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS'),
                    usernamePassword(credentialsId: 'ES_CREDENTIALS', usernameVariable: 'ES_USER', passwordVariable: 'ES_PASS')
                ]) {
                    withCredentials([sshUserPrivateKey(credentialsId: 'ec2-deploy-key', keyFileVariable: 'SSH_KEY')]) {
                        sh """
                            # Inject secrets securely without exposing them in shell history
                            ssh -i \$SSH_KEY -o StrictHostKeyChecking=no ${EC2_USER}@${params.EC2_HOST} '
                                kubectl create secret generic catalogue-service-secrets -n ${APP_NAMESPACE} \\
                                    --from-literal=SPRING_DATASOURCE_USERNAME="\${DB_USER}" \\
                                    --from-literal=SPRING_DATASOURCE_PASSWORD="\${DB_PASS}" \\
                                    --from-literal=ELASTICSEARCH_USERNAME="\${ES_USER}" \\
                                    --from-literal=ELASTICSEARCH_PASSWORD="\${ES_PASS}" \\
                                    --dry-run=client -o yaml | kubectl apply -f -
                            '

                            # Copy the helm charts to the EC2 instance
                            scp -i \$SSH_KEY -o StrictHostKeyChecking=no -r ./helm ${EC2_USER}@${params.EC2_HOST}:~/helm

                            # Deploy the application
                            ssh -i \$SSH_KEY -o StrictHostKeyChecking=no ${EC2_USER}@${params.EC2_HOST} '
                                if /usr/local/bin/helm status ${HELM_RELEASE} -n ${APP_NAMESPACE} >/dev/null 2>&1; then
                                    /usr/local/bin/helm upgrade ${HELM_RELEASE} ~/${HELM_CHART} \\
                                        -n ${APP_NAMESPACE} --reuse-values --set image.tag=${IMAGE_TAG}
                                else
                                    /usr/local/bin/helm upgrade --install ${HELM_RELEASE} ~/${HELM_CHART} \\
                                        -n ${APP_NAMESPACE} \\
                                        --set image.repository=${ECR_REPO} \\
                                        --set image.tag=${IMAGE_TAG}
                                fi
                            '
                        """
                    }
                }
            }
        }

        stage('Smoke Test') {
            steps {
                sh """
                    curl -sf http://${params.EC2_HOST}:30080/${SMOKE_PREFIX}/v1/read/smoketest \
                        -H "apikey: ${SMOKE_API_KEY}" || exit 1
                """
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed — check stage logs above for details."
        }
        success {
            echo "Deployment of ${IMAGE_TAG} completed successfully."
        }
    }
}
