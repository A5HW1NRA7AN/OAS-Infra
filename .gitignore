# ============================
# OAS-Infra .gitignore
# ============================

# --- Terraform (kept from original — does no harm) ---
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc

# --- Credentials & secrets ---
# Kong config with real API keys (only the template with <CHANGE_ME> is committed)
kong/kong-secrets.yml
.env
*.pem
*.key
*.kubeconfig
kubeconfig

# --- Helm ---
# Packaged chart archives
*.tgz
# Downloaded chart dependencies
helm/*/charts/
# Chart lock file
helm/*/Chart.lock

# --- IDE & OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- Terraform Generated scripts ---
env.sh
hosts_k8s.yaml
scratch_kubeconfig

# --- Internal Agent & Docs (Do not push) ---
.agents/
docs/