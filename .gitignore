# ============================
# OAS-Infra .gitignore
# ============================

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc

# --- Credentials & secrets ---
.env
*.pem
*.key
*.kubeconfig
kubeconfig

# --- Terraform generated outputs ---
env.sh
hosts_k8s.yaml
scratch_kubeconfig
*.bak

# --- Helm ---
*.tgz
helm/*/charts/
helm/*/Chart.lock

# --- IDE & OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- Scratch / debug files ---
scratch/

# --- One-off scripts ---
fix_kong.py

# --- Agent artifacts (session-specific, not project code) ---
AGENTS.md
implementation_plan.md
walkthrough.md
.agents/
docs/

# --- Postman (generated locally, not core infra) ---
*.postman_collection.json
*.postman_test_run.json
scripts/generate-postman.py

# --- Management UIs manifest (deployed ad-hoc, not part of core chart) ---
helm/management-uis.yaml

# --- Misc ---
website-imp.txt