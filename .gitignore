# ============================
# OAS-Infra .gitignore
# ============================

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc

# --- Credentials & secrets ---
.env
*.pem
*.key
*.kubeconfig
kubeconfig

# --- Terraform generated outputs ---
env.sh
hosts_k8s.yaml
scratch_kubeconfig
*.bak

# --- Helm ---
*.tgz
helm/*/charts/
helm/*/Chart.lock

# --- IDE & OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- Scratch / debug files ---
scratch/

# --- Agent & local development artifacts (local only — never pushed to git) ---
# These support our own testing/development workflow and are not part of the
# core files a developer needs to fork and set up the repository.
.agents/
.claude/
AGENTS.md
CLAUDE.md
docs/